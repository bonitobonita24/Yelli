// =============================================================
// Yelli — Prisma Schema
// Generated by Phase 4 Part 3a (Spec-Driven Platform V31)
//
// TENANCY NOTE: There is NO separate Tenant model in this schema.
// Organization IS the tenant root. Every tenant-scoped entity carries
// an organization_id column that references Organization.id.
// This is intentional — the Tenant model described in generic V31
// docs maps directly to Organization in the Yelli domain.
//
// MULTI-TENANT ISOLATION STRATEGY: shared schema + organization_id.
// L6 Prisma tenant-guard auto-injects organizationId on every query.
// L2 PostgreSQL RLS policies are scaffolded as comments (DORMANT in
// single-tenant self-hosted mode; activated on SaaS tier deployment).
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum PlanTier {
  free
  pro
  enterprise

  @@map("plan_tier")
}

enum SubscriptionStatus {
  active
  past_due
  cancelled
  trialing

  @@map("subscription_status")
}

enum UserRole {
  tenant_admin
  host
  participant

  @@map("user_role")
}

enum UserStatus {
  active
  inactive

  @@map("user_status")
}

enum InvoiceStatus {
  paid
  pending
  failed
  refunded

  @@map("invoice_status")
}

// ─────────────────────────────────────────────────────────────
// Organization (Tenant Root)
// ─────────────────────────────────────────────────────────────

model Organization {
  id                  String             @id @default(cuid())
  name                String             @db.VarChar(200)
  slug                String             @unique @db.VarChar(100)
  plan_tier           PlanTier           @default(free)
  subscription_status SubscriptionStatus @default(trialing)
  billing_email       String
  suspended_at        DateTime?

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  users                User[]
  departments          Department[]
  subscriptions        Subscription[]
  invoices             Invoice[]
  audit_logs           AuditLog[]
  meetings             Meeting[]
  call_logs            CallLog[]
  recordings           Recording[]
  participants         Participant[]
  chat_messages        ChatMessage[]
  shared_files         SharedFile[]
  whiteboard_snapshots WhiteboardSnapshot[]

  @@map("organizations")
}

// -- RLS (DORMANT — activate on SaaS multi-tenant deployment):
// -- ALTER TABLE "organizations" ENABLE ROW LEVEL SECURITY;
// -- CREATE POLICY tenant_isolation ON "organizations"
// --   USING (id = current_setting('app.current_tenant_id')::text);

// ─────────────────────────────────────────────────────────────
// User
// ─────────────────────────────────────────────────────────────

model User {
  id               String     @id @default(cuid())
  organization_id  String
  email            String
  password_hash    String
  display_name     String     @db.VarChar(200)
  role             UserRole   @default(participant)
  is_super_admin   Boolean    @default(false)
  avatar_url       String?
  status           UserStatus @default(active)
  last_seen_at     DateTime?
  security_version Int        @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  organization        Organization  @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  audit_logs          AuditLog[]
  hosted_meetings     Meeting[]
  participations      Participant[]
  made_call_logs      CallLog[]
  sent_chat_messages  ChatMessage[]
  recorded_recordings Recording[]
  uploaded_files      SharedFile[]

  @@unique([organization_id, email])
  @@index([organization_id])
  @@index([email])
  @@map("users")
}

// -- RLS (DORMANT):
// -- ALTER TABLE "users" ENABLE ROW LEVEL SECURITY;
// -- CREATE POLICY tenant_isolation ON "users"
// --   USING (organization_id = current_setting('app.current_tenant_id')::text);

// ─────────────────────────────────────────────────────────────
// Department
// ─────────────────────────────────────────────────────────────

model Department {
  id                   String  @id @default(cuid())
  organization_id      String
  name                 String  @db.VarChar(200)
  description          String?
  group_label          String?
  sort_order           Int     @default(0)
  device_binding_token String? @unique
  auto_answer_enabled  Boolean @default(false)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  organization         Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  outgoing_call_logs   CallLog[]    @relation("CallerDepartment")
  incoming_call_logs   CallLog[]    @relation("RecipientDepartment")

  @@index([organization_id])
  @@map("departments")
}

// -- RLS (DORMANT):
// -- ALTER TABLE "departments" ENABLE ROW LEVEL SECURITY;
// -- CREATE POLICY tenant_isolation ON "departments"
// --   USING (organization_id = current_setting('app.current_tenant_id')::text);

// ─────────────────────────────────────────────────────────────
// Subscription
// ─────────────────────────────────────────────────────────────

model Subscription {
  id                                  String             @id @default(cuid())
  organization_id                     String
  plan_tier                           PlanTier
  xendit_subscription_id              String?            @unique
  payment_method                      String?
  status                              SubscriptionStatus @default(trialing)
  current_period_start                DateTime
  current_period_end                  DateTime
  minutes_used_this_period            Int                @default(0)
  recording_minutes_used_this_period  Int                @default(0)

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relations
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  invoices     Invoice[]

  @@index([organization_id])
  @@index([status])
  @@map("subscriptions")
}

// -- RLS (DORMANT):
// -- ALTER TABLE "subscriptions" ENABLE ROW LEVEL SECURITY;
// -- CREATE POLICY tenant_isolation ON "subscriptions"
// --   USING (organization_id = current_setting('app.current_tenant_id')::text);

// ─────────────────────────────────────────────────────────────
// Invoice
// ─────────────────────────────────────────────────────────────

model Invoice {
  id               String        @id @default(cuid())
  organization_id  String
  subscription_id  String
  xendit_invoice_id String
  amount_cents     Int
  currency         String        @default("PHP") @db.Char(3)
  status           InvoiceStatus @default(pending)
  issued_at        DateTime
  paid_at          DateTime?
  pdf_url          String?

  // Relations
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  subscription Subscription  @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([subscription_id])
  @@index([xendit_invoice_id])
  @@map("invoices")
}

// -- RLS (DORMANT):
// -- ALTER TABLE "invoices" ENABLE ROW LEVEL SECURITY;
// -- CREATE POLICY tenant_isolation ON "invoices"
// --   USING (organization_id = current_setting('app.current_tenant_id')::text);

// ─────────────────────────────────────────────────────────────
// PlatformSettings (singleton)
// ─────────────────────────────────────────────────────────────

model PlatformSettings {
  // Singleton — always access via id = "singleton"
  id                           String @id @default("singleton")
  free_tier_group_call_limit_minutes Int @default(45)
  free_tier_max_participants        Int @default(8)
  pro_tier_price_cents              Int @default(299900)
  enterprise_tier_price_cents       Int @default(849900)
  recording_storage_quota_gb        Int

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@map("platform_settings")
}

// ─────────────────────────────────────────────────────────────
// AuditLog (L5 — always active, immutable)
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id              String   @id @default(cuid())
  organization_id String?
  user_id         String?
  action          String   // CREATE | UPDATE | DELETE | PLATFORM:*
  entity          String   // table name
  entity_id       String
  before          Json?
  after           Json?
  created_at      DateTime @default(now())

  // Relations (nullable — platform-level actions may have no org/user)
  organization Organization? @relation(fields: [organization_id], references: [id], onDelete: SetNull)
  user         User?          @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([user_id])
  @@index([entity, entity_id])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// Meeting / Call / Realtime Entities (Part 3b)
// ─────────────────────────────────────────────────────────────
// All meeting-scoped child entities (Participant, ChatMessage,
// SharedFile, WhiteboardSnapshot) carry a denormalized
// organization_id column so the L6 tenant-guard ($allOperations)
// can inject the same WHERE filter uniformly across every model.
// This trades 16 bytes per row for a structural security guarantee
// (no resolver can accidentally omit the tenant filter).

enum MeetingStatus {
  scheduled
  active
  ended
  cancelled

  @@map("meeting_status")
}

enum ParticipantRole {
  host
  moderator
  participant
  guest

  @@map("participant_role")
}

enum CallType {
  intercom
  meeting

  @@map("call_type")
}

enum CallStatus {
  completed
  missed
  failed

  @@map("call_status")
}

enum MessageType {
  text
  file
  system

  @@map("message_type")
}

enum StorageType {
  local
  s3

  @@map("storage_type")
}

enum RecordingStatus {
  processing
  ready
  failed
  deleted

  @@map("recording_status")
}

// ─────────────────────────────────────────────────────────────
// Meeting
// ─────────────────────────────────────────────────────────────

model Meeting {
  id                 String        @id @default(cuid())
  organization_id    String
  host_user_id       String
  title              String        @db.VarChar(300)
  description        String?
  scheduled_at       DateTime?
  started_at         DateTime?
  ended_at           DateTime?
  meeting_link_token String        @unique
  status             MeetingStatus @default(scheduled)
  recording_enabled  Boolean       @default(false)
  livekit_room_name  String
  lobby_enabled      Boolean       @default(false)
  locked             Boolean       @default(false)

  created_at DateTime @default(now())

  // Relations
  organization         Organization         @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  host                 User                 @relation(fields: [host_user_id], references: [id], onDelete: Restrict)
  participants         Participant[]
  chat_messages        ChatMessage[]
  recordings           Recording[]
  shared_files         SharedFile[]
  whiteboard_snapshots WhiteboardSnapshot[]
  call_logs            CallLog[]

  @@index([organization_id])
  @@index([host_user_id])
  @@index([status])
  @@index([livekit_room_name])
  @@map("meetings")
}

// -- RLS (DORMANT):
// -- ALTER TABLE "meetings" ENABLE ROW LEVEL SECURITY;
// -- CREATE POLICY tenant_isolation ON "meetings"
// --   USING (organization_id = current_setting('app.current_tenant_id')::text);

// ─────────────────────────────────────────────────────────────
// Participant
// ─────────────────────────────────────────────────────────────

model Participant {
  id                 String          @id @default(cuid())
  organization_id    String
  meeting_id         String
  user_id            String?
  guest_display_name String?
  role_in_meeting    ParticipantRole @default(participant)
  joined_at          DateTime        @default(now())
  left_at            DateTime?

  // Relations
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  meeting      Meeting      @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [user_id], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([meeting_id])
  @@index([user_id])
  @@map("participants")
}

// -- RLS (DORMANT):
// -- ALTER TABLE "participants" ENABLE ROW LEVEL SECURITY;
// -- CREATE POLICY tenant_isolation ON "participants"
// --   USING (organization_id = current_setting('app.current_tenant_id')::text);

// ─────────────────────────────────────────────────────────────
// CallLog
// ─────────────────────────────────────────────────────────────

model CallLog {
  id                      String     @id @default(cuid())
  organization_id         String
  meeting_id              String?
  caller_user_id          String?
  caller_department_id    String?
  recipient_department_id String?
  call_type               CallType
  started_at              DateTime
  ended_at                DateTime?
  participant_count       Int        @default(0)
  status                  CallStatus

  created_at DateTime @default(now())

  // Relations
  organization         Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  meeting              Meeting?     @relation(fields: [meeting_id], references: [id], onDelete: SetNull)
  caller               User?        @relation(fields: [caller_user_id], references: [id], onDelete: SetNull)
  caller_department    Department?  @relation("CallerDepartment", fields: [caller_department_id], references: [id], onDelete: SetNull)
  recipient_department Department?  @relation("RecipientDepartment", fields: [recipient_department_id], references: [id], onDelete: SetNull)
  recordings           Recording[]

  @@index([organization_id])
  @@index([meeting_id])
  @@index([caller_user_id])
  @@index([started_at(sort: Desc)])
  @@map("call_logs")
}

// -- RLS (DORMANT):
// -- ALTER TABLE "call_logs" ENABLE ROW LEVEL SECURITY;
// -- CREATE POLICY tenant_isolation ON "call_logs"
// --   USING (organization_id = current_setting('app.current_tenant_id')::text);

// ─────────────────────────────────────────────────────────────
// ChatMessage
// ─────────────────────────────────────────────────────────────

model ChatMessage {
  id                String      @id @default(cuid())
  organization_id   String
  meeting_id        String
  sender_user_id    String?
  sender_guest_name String?
  content           String      @db.Text
  message_type      MessageType @default(text)
  file_url          String?

  created_at DateTime @default(now())

  // Relations
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  meeting      Meeting      @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  sender       User?        @relation(fields: [sender_user_id], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([meeting_id, created_at])
  @@map("chat_messages")
}

// -- RLS (DORMANT):
// -- ALTER TABLE "chat_messages" ENABLE ROW LEVEL SECURITY;
// -- CREATE POLICY tenant_isolation ON "chat_messages"
// --   USING (organization_id = current_setting('app.current_tenant_id')::text);

// ─────────────────────────────────────────────────────────────
// Recording
// ─────────────────────────────────────────────────────────────

model Recording {
  id                  String          @id @default(cuid())
  organization_id     String
  meeting_id          String
  call_log_id         String
  file_path           String
  file_size_bytes     BigInt
  duration_seconds    Int
  storage_type        StorageType     @default(local)
  status              RecordingStatus @default(processing)
  recorded_by_user_id String

  created_at DateTime  @default(now())
  deleted_at DateTime?

  // Relations
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  meeting      Meeting      @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  call_log     CallLog      @relation(fields: [call_log_id], references: [id], onDelete: Cascade)
  recorded_by  User         @relation(fields: [recorded_by_user_id], references: [id], onDelete: Restrict)

  @@index([organization_id])
  @@index([meeting_id])
  @@index([call_log_id])
  @@index([status])
  @@map("recordings")
}

// -- RLS (DORMANT):
// -- ALTER TABLE "recordings" ENABLE ROW LEVEL SECURITY;
// -- CREATE POLICY tenant_isolation ON "recordings"
// --   USING (organization_id = current_setting('app.current_tenant_id')::text);

// ─────────────────────────────────────────────────────────────
// SharedFile
// ─────────────────────────────────────────────────────────────

model SharedFile {
  id                     String  @id @default(cuid())
  organization_id        String
  meeting_id             String
  uploaded_by_user_id    String?
  uploaded_by_guest_name String?
  file_name              String  @db.VarChar(500)
  file_path              String
  file_size_bytes        BigInt
  mime_type              String  @db.VarChar(255)
  is_persisted           Boolean @default(false)

  created_at DateTime  @default(now())
  expires_at DateTime?

  // Relations
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  meeting      Meeting      @relation(fields: [meeting_id], references: [id], onDelete: Cascade)
  uploader     User?        @relation(fields: [uploaded_by_user_id], references: [id], onDelete: SetNull)

  @@index([organization_id])
  @@index([meeting_id])
  @@index([expires_at])
  @@map("shared_files")
}

// -- RLS (DORMANT):
// -- ALTER TABLE "shared_files" ENABLE ROW LEVEL SECURITY;
// -- CREATE POLICY tenant_isolation ON "shared_files"
// --   USING (organization_id = current_setting('app.current_tenant_id')::text);

// ─────────────────────────────────────────────────────────────
// WhiteboardSnapshot
// ─────────────────────────────────────────────────────────────

model WhiteboardSnapshot {
  id              String  @id @default(cuid())
  organization_id String
  meeting_id      String
  snapshot_data   Json
  is_persisted    Boolean @default(false)

  created_at DateTime @default(now())

  // Relations
  organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  meeting      Meeting      @relation(fields: [meeting_id], references: [id], onDelete: Cascade)

  @@index([organization_id])
  @@index([meeting_id])
  @@map("whiteboard_snapshots")
}

