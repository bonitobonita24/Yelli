# Template — copy to .env.test.e2e and fill in real values
# .env.test.e2e is gitignored (contains WEBMASTER_PASSWORD — never commit)
#
# ─────────────────────────────────────────────────────────────
# Local / CI parity for the E2E bypass auth provider
# ─────────────────────────────────────────────────────────────
# Local dev:  copy this file → .env.test.e2e; Playwright reads it via dotenv.
# CI:         the same vars are injected via GitHub Actions secrets + the
#             workflow's env: block (see .github/workflows/ci.yml playwright job).
# Both paths must set LIVEKIT_E2E_MOCK=true — it gates the bypass auth provider.
# NEVER set LIVEKIT_E2E_MOCK in .env.staging or .env.prod.

# Bypass-auth password for the seeded webmaster user.
# Local: must match the webmaster password produced by `pnpm db:seed`
#        (look it up in CREDENTIALS.md "First Admin Account" section).
# CI:    provided via the WEBMASTER_PASSWORD repository secret.
WEBMASTER_PASSWORD=your-webmaster-password-here

# Playwright base URL.
# Local: http://localhost:3000 (Next.js dev server via `pnpm dev`).
# CI:    matches the test server started by the playwright job.
PLAYWRIGHT_BASE_URL=http://localhost:3000

# REQUIRED — enables the e2e bypass auth provider in apps/web.
# Both local and CI must set this to "true".
# Production environments must NOT set this — the provider is dev/test only.
LIVEKIT_E2E_MOCK=true
