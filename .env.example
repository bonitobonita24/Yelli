# ═══════════════════════════════════════════════════════════════════
# Yelli — Environment Variables Template
# ═══════════════════════════════════════════════════════════════════
# HOW TO USE:
# 1. Copy this file: cp .env.example .env.dev
# 2. Fill in real values (or run Phase 3 to auto-generate them)
# 3. NEVER commit .env.dev, .env.staging, or .env.prod to git
# 4. NEVER commit CREDENTIALS.md to git (it is gitignored)
#
# FIRST ADMIN ACCOUNT (created by pnpm db:seed):
#   Username: webmaster
#   Password: see CREDENTIALS.md (gitignored — generated by Bootstrap Step 18)
#   URL: http://localhost:[APP_PORT]/login
#
# All service passwords in CREDENTIALS.md are AI-generated strong passwords.
# Anyone cloning this repo must generate their own via Phase 3.
# ═══════════════════════════════════════════════════════════════════
COMPOSE_PROJECT_NAME=yelli_dev
APP_ENV=development|staging|production
APP_PORT=43512

# DATABASE
DB_HOST=localhost
DB_PORT=43502
DB_NAME=yelli_dev
DB_USER=yelli_your_hex_suffix_here
DB_PASSWORD=your-db-password-here
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# PGBOUNCER
PGBOUNCER_PORT=43503
PGBOUNCER_AUTH_PASSWORD=your-pgbouncer-password-here
PGBOUNCER_DATABASE_URL=postgresql://${DB_USER}:${PGBOUNCER_AUTH_PASSWORD}@localhost:${PGBOUNCER_PORT}/${DB_NAME}

# CACHE (Valkey)
REDIS_HOST=localhost
REDIS_PORT=43504
REDIS_PASSWORD=your-redis-password-here
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# FILE STORAGE (MinIO)
STORAGE_ENDPOINT=http://localhost:43505
STORAGE_PORT=43505
STORAGE_CONSOLE_PORT=43506
STORAGE_BUCKET=yelli-dev
STORAGE_ACCESS_KEY=yelli-your_hex_suffix_here
STORAGE_SECRET_KEY=your-48-char-storage-secret-key-here
STORAGE_REGION=us-east-1

# AUTH (Auth.js v5)
AUTH_SECRET=your-48-char-auth-secret-here
NEXTAUTH_URL=http://localhost:43512

# EMAIL (MailHog in dev, real SMTP in staging/prod)
SMTP_HOST=localhost
SMTP_PORT=43507
SMTP_FROM=noreply@yourdomain.com
SMTP_FROM_NAME=Yelli
# SMTP_USER=                    # staging/prod only
# SMTP_PASSWORD=                # staging/prod only

# PGADMIN
PGADMIN_PORT=43509
PGADMIN_EMAIL=your-pgadmin-email-here
PGADMIN_PASSWORD=your-pgadmin-password-here

# LIVEKIT (Yelli core — self-hosted SFU)
LIVEKIT_URL=ws://localhost:43532
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
LIVEKIT_SIGNAL_PORT=43532
LIVEKIT_TURN_UDP_START=43537

# COTURN (TURN/STUN for NAT traversal)
COTURN_PORT=43542
COTURN_REALM=your-domain.local
COTURN_STATIC_AUTH_SECRET=your-turn-secret-here

# XENDIT (payment gateway — TEST keys for dev/staging, LIVE keys for prod)
XENDIT_SECRET_KEY=xnd_development_your_test_secret_key_here
XENDIT_PUBLIC_KEY=xnd_public_development_your_test_public_key_here
XENDIT_WEBHOOK_TOKEN=your-xendit-webhook-verification-token-here

# CLOUDFLARE TURNSTILE (bot protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
# ↑ These are Cloudflare's official test keys (always pass). Replace with real keys for prod.

# DOCKER HUB (image registry)
DOCKERHUB_USERNAME=bonitobonita24
IMAGE_NAME=yelli
APP_IMAGE_TAG=dev-latest
